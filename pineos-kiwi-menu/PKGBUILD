pkgname=pineos-kiwi-menu
pkgver=0.2.3
pkgrel=1
pkgdesc="macOS-inspired quick menu for GNOME (PineOS Edition, originally by kem-a)"
arch=('any')
url="https://github.com/The-Pine-Project/kiwi-menu"
license=('GPL3')
depends=('gnome-shell')
makedepends=('git')
source=("git+https://github.com/The-Pine-Project/kiwi-menu.git")
sha256sums=('SKIP')

package() {
    cd kiwi-menu
    # Extract the extension UUID from metadata.json dynamically
    _uuid=$(grep -Po '(?<="uuid": ")[^"]*' metadata.json)
    install -d "$pkgdir/usr/share/gnome-shell/extensions/${_uuid}"
    cp -r * "$pkgdir/usr/share/gnome-shell/extensions/${_uuid}/"
}
